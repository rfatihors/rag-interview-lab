# Runtime
APP_ENV=local
LOG_LEVEL=INFO

# Provider selection: mock | openai | ollama
LLM_PROVIDER=mock

# OpenAI
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=gemma3
OLLAMA_EMBED_MODEL=embeddinggemma

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=rag_interview_docs

# Retrieval
TOP_K=5
MIN_SCORE=0.35

# Paths
DOCS_DIR=data/sample_docs
